# Server
PORT=3001
FRONTEND_URL="http://localhost:5173"
# Docker + Cloudflare quick tunnel (docker compose --profile tunnel): разрешить https://*.trycloudflare.com
# CORS_ALLOW_TRY_CLOUDFLARE=true
# Docker + ngrok tunnel (docker compose --profile tunnel-ngrok): разрешить https://*.ngrok-free.app
# CORS_ALLOW_NGROK=true
# Docker + localtunnel (docker compose --profile tunnel-lt): разрешить https://*.loca.lt
# CORS_ALLOW_LOCALTUNNEL=true

# Private deployments: disable open sign-up (admin can still create users)
# PUBLIC_REGISTRATION=false
# PHONE_SIGNUP_ENABLED=false

# Optional: bootstrap first admin (email + password). User is created/updated on server start.
# ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD="change-me-strong"
# If you already have an account with username truble_admin but different email, on restart promote isAdmin:
# ADMIN_PROMOTE_USERNAME=truble_admin

# Test user Bubble_Bot (DM / groups). Created or updated on startup. Disable: BUBBLE_BOT_SEED=0
# BUBBLE_BOT_EMAIL="bubble_bot@local.trublebubble"
# BUBBLE_BOT_PASSWORD="BubbleBot_Test_1"

# Bubble_Bot — system prompt: bubble-bot-prompt.txt in project root (or BUBBLE_BOT_PROMPT_PATH)
# BUBBLE_BOT_PROMPT_PATH=../bubble-bot-prompt.txt
#
# Google Gemini (recommended if you have no OpenAI key)
# GEMINI_API_KEY=
# Direct Google (default):
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# Mirror / proxy (e.g. Russia-friendly; path /v1beta/models/... is appended automatically):
# GEMINI_BASE_URL=https://api.genai.gd.edu.kg/google
# If the mirror rejects ?key= in URL, use header instead:
# GEMINI_API_KEY_IN_HEADER=true
# Optional HTTP(S) proxy for outbound requests (corporate proxy; not the same as GEMINI_BASE_URL):
# GEMINI_HTTPS_PROXY=http://127.0.0.1:7890
# OR HTTPS_PROXY=http://127.0.0.1:7890
# GEMINI_API_VERSION=v1beta
# Prefer a current stable id (bare gemini-1.5-pro often 404s):
# GEMINI_MODEL=gemini-2.5-flash
# If one model returns 404, the server tries other built-in fallbacks. Avoid gemini-1.5-flash-8b — often 404 on generateContent.
#
# OpenAI-compatible Chat Completions (Bubble_Bot order: custom OPENAI_BASE_URL first e.g. Minimax, then Gemini, then plain OpenAI)
# Minimax / custom: set OPENAI_BASE_URL to provider; OPENAI_API_KEY = provider key
# When primary returns 429/402: OPENAI_FALLBACK_API_KEY is used with https://api.openai.com/v1 (OpenAI proper)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_FALLBACK_API_KEY=
# OPENAI_FALLBACK_MODEL=gpt-4o-mini

# File Upload (Docker: set UPLOAD_DIR=/app/uploads and mount volume — see docker-compose.yml)
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=2147483648

# Optional: S3-compatible object storage (files survive Render redeploys; DB stores full https URLs).
# Full Yandex Object Storage walkthrough: docs/YANDEX_OBJECT_STORAGE.md
#
# --- Yandex Cloud Object Storage (example) ---
# S3_ENDPOINT=https://storage.yandexcloud.net
# S3_REGION=ru-central1
# S3_ACCESS_KEY_ID=<static key id>
# S3_SECRET_ACCESS_KEY=<static key secret>
# S3_BUCKET=your-bucket-name
# S3_PUBLIC_BASE_URL=https://storage.yandexcloud.net/your-bucket-name
# S3_KEY_PREFIX=
# (forcePathStyle is auto-true for storage.yandexcloud.net; override: S3_FORCE_PATH_STYLE=true|false)
#
# --- Cloudflare R2 (example) ---
# S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# S3_FORCE_PATH_STYLE=0

# ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD="change-me-strong"

