# Optional: same-origin API (empty = browser origin; use http://localhost:3001 only for special setups)
# VITE_API_URL=
# VITE_WS_URL=

# If uploads return 404 (e.g. dev on port 5175 without proxy), set API origin so /uploads loads from backend:
# VITE_API_URL=http://localhost:3001

# Build-time: always emit verbose [TrubleBubble:debug] logs in production bundle
# VITE_DEBUG_UI=true
